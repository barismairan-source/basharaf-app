# ─────────────────────────────────────────────────────────────────
# با شرف — Environment Variables
# این فایل را به .env.local کپی کنید
# ─────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ─────────────────────────────────────────
# هر PostgreSQL ارائه‌دهنده‌ای کار می‌کند (Liara DB، Supabase، Neon، …)
# برای Supabase: Connect → Transaction pooler (port 6543)
# برای Liara DB: از Dashboard → Database → Connection String
DATABASE_URL=postgres://user:PASSWORD@db-host:5432/dbname
DATABASE_SSL=require

# ── JWT ───────────────────────────────────────────────────────────
# حداقل ۳۲ کاراکتر — openssl rand -base64 32
JWT_SECRET=your-secret-key-min-32-chars-here

# ── App URL ───────────────────────────────────────────────────────
# برای لینک‌های داخل اعلان‌ها و ایمیل‌ها (الزامی در production)
NEXT_PUBLIC_APP_URL=https://basharaf.me
# APP_URL فقط برای scripts/process-notifications.mjs — اگر از cron خارجی استفاده می‌کنید، نیازی ندارید
APP_URL=https://basharaf.me

# ── Supabase Realtime (فاز ۱۴) ───────────────────────────────────
# از Supabase Dashboard: Settings → API
# Project URL و anon key را کپی کنید
# اگر این دو را ندهید، Real-time غیرفعال می‌شود (سیستم عادی کار می‌کند)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase Storage (فاز ۱۶) ─────────────────────────────────────
# برای آپلود فایل رسید — service_role key (فقط server-side)
# از Supabase Dashboard: Settings → API → service_role
# ⚠ این key را NEVER در NEXT_PUBLIC_ قرار ندهید!
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── SMS / Kavenegar (Notification Center V2) ─────────────────────
# برای ارسال پیامک از طریق کاوه‌نگار
# اگر تنظیم نشود، کانال پیامک غیرفعال می‌شود (سیستم عادی کار می‌کند)
KAVENEGAR_API_KEY=your-kavenegar-api-key
# SMS_DRY_RUN=true  پیامک‌ها را لاگ می‌کند اما ارسال نمی‌کند (برای تست)
SMS_DRY_RUN=

# ── SMTP Email (Notification Center V2) ──────────────────────────
# برای ارسال ایمیل از طریق سرویس Liara Mail یا هر SMTP دیگری
# اگر این متغیرها تنظیم نشوند، کانال ایمیل غیرفعال می‌شود (سیستم عادی کار می‌کند)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=notifications@yourdomain.com
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=notifications@yourdomain.com
# اختیاری: MAIL_SECURE=true  فقط برای port 465
# اختیاری: MAIL_REPLY_TO=support@yourdomain.com
MAIL_SECURE=
MAIL_REPLY_TO=

# ── Notification Processor Secret (Notification Center V2) ───────
# حداقل ۳۲ کاراکتر — openssl rand -base64 32
# برای احراز هویت endpoint داخلی /api/internal/notifications/process
NOTIFICATION_PROCESSOR_SECRET=your-processor-secret-min-32-chars-here
