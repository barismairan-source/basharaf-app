# E2E test environment — copy to .env.e2e and fill in real values.
# NEVER commit .env.e2e — it is listed in .gitignore.
# These variables must point to a development or test database only.

# Required: PostgreSQL connection string for the E2E test database (NOT production).
E2E_DATABASE_URL=postgres://user:password@localhost:5432/basharaf_test

# Required: explicit opt-in confirming this is a development or test database.
# Set to 1 only after verifying the connection string above is not production.
E2E_ALLOW_DB_MUTATION=1
